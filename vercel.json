    {
      "path": "/api/cron/generate-daily",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/generate-weekly",
      "schedule": "10 22 * * 0"
    },
    {
      "path": "/api/cron/generate-monthly",
      "schedule": "20 22 * * *"
    },
    {
      "path": "/api/cron/update-astro-calendar",
      "schedule": "30 22 * * 0"
    },
    {
      "path": "/api/cron/refresh-sitemap",
      "schedule": "40 22 * * *"
    }
  ]
}
